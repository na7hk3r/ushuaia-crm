{
  "name": "ushuaia-crm",
  "private": true,
  "version": "1.1.7",
  "type": "module",
  "main": "electron/main.js",
  "description": "Ushuaia CRM — Gestión integral de alfajores",
  "author": "Ushuaia Alfajores",
  "homepage": "https://na7hk3r.github.io/ushuaia-crm/",
  "repository": {
    "type": "git",
    "url": "https://github.com/na7hk3r/ushuaia-crm.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "vite build && electron-builder",
    "electron:preview": "vite build && electron .",
    "dist": "vite build && electron-builder",
    "release": "node scripts/release.js"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@rolldown/plugin-babel": "^0.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "canvas": "^3.2.2",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.0",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.ushuaia.crm",
    "productName": "Ushuaia CRM",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "na7hk3r",
        "repo": "ushuaia-crm",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Ushuaia CRM",
      "uninstallDisplayName": "Ushuaia CRM",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "UshuaiaCRM-Setup-${version}.${ext}",
      "installerHeader": "build/installerHeader.bmp",
      "installerSidebar": "build/installerSidebar.bmp",
      "deleteAppDataOnUninstall": false
    }
  }
}
